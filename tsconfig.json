{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"paths": {
			"@/*": ["src/*"]
		},
		"resolvePackageJsonImports": true,
		"strict": true,
		"target": "ES2022",
		"types": ["node"]
	},
	"include": ["src/**/*.ts"]
}
