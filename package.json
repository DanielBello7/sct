{
	"name": "sctree",
	"version": "0.1.0",
	"type": "module",
	"bin": {
		"sct": "./bin/sct"
	},
	"files": [
		"bin",
		"dist",
		"docs",
		"README.md"
	],
	"scripts": {
		"sct:dev": "tsx -r tsconfig-paths/register src/app.ts",
		"sct": "node dist/app.js",
		"typecheck": "tsc --noEmit",
		"build": "tsc && resolve-tspaths --out dist"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^25.9.3",
		"resolve-tspaths": "^0.8.23",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@clack/prompts": "^1.5.1",
		"commander": "^15.0.0",
		"fs-extra": "^11.3.5",
		"picocolors": "^1.1.1"
	}
}
