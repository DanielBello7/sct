{
	"name": "sctree-cli",
	"version": "0.2.0",
	"type": "module",
	"bin": {
		"sctree": "./bin/sctree"
	},
	"files": [
		"bin",
		"dist",
		"docs",
		"README.md"
	],
	"scripts": {
		"sctree:dev": "tsx -r tsconfig-paths/register src/app.ts",
		"sctree": "node dist/app.js",
		"test": "mocha --node-option import=tsx \"__tests__/**/*.test.ts\"",
		"test:build": "npm run build && npm test",
		"typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
		"build": "tsc && resolve-tspaths --out dist"
	},
	"devDependencies": {
		"@types/chai": "^5.2.3",
		"@types/fs-extra": "^11.0.4",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.9.3",
		"chai": "^6.2.2",
		"mocha": "^11.7.6",
		"resolve-tspaths": "^0.8.23",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@clack/prompts": "^1.5.1",
		"commander": "^15.0.0",
		"fs-extra": "^11.3.5",
		"picocolors": "^1.1.1"
	}
}
